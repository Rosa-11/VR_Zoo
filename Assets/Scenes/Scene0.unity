  - isPlayerSpeaking: 1
    speakerName: "\u73A9\u5BB6"
    dialogueText: "\u8FD9\u662F\u54EA\u91CC\uFF1F\u6211\u4E3A\u4EC0\u4E48\u4F1A\u5728\u8FD9\u91CC\uFF1F"
    displayDuration: 2.5
  - isPlayerSpeaking: 0
    speakerName: "\u8BFA\u4E9A"
    dialogueText: "\u6B22\u8FCE\u6765\u5230\u827E\u745F\u62C9\u4E16\u754C\u3002\u4F60\u88AB\u9009\u4E2D\u6765\u5230\u8FD9\u91CC\uFF0C\u56E0\u4E3A\u9ED1\u6697\u6B63\u5728\u8513\u5EF6\uFF0C\u6211\u4EEC\u9700\u8981\u4F60\u7684\u5E2E\u52A9\u3002"
    displayDuration: 4
  - isPlayerSpeaking: 1
    speakerName: "\u73A9\u5BB6"
    dialogueText: "\u6211\u80FD\u505A\u4EC0\u4E48\uFF1F\u6211\u53EA\u662F\u4E2A\u666E\u901A\u4EBA\u3002"
    displayDuration: 2.5
  - isPlayerSpeaking: 0
    speakerName: "\u8BFA\u4E9A"
    dialogueText: "\u6BCF\u4E2A\u4EBA\u90FD\u6709\u81EA\u5DF1\u7684\u529B\u91CF\u3002\u73B0\u5728\uFF0C\u662F\u65F6\u5019\u5F00\u59CB\u4F60\u7684\u65C5\u7A0B\u4E86\u3002\u795D\u4F60\u597D\u8FD0\uFF0C\u52C7\u58EB\u3002"
