  - isPlayerSpeaking: 0
    speakerName: "\u8BFA\u4E9A"
    dialogueText: "\u4F60\u597D\uFF0C\u964C\u751F\u7684\u65C5\u884C\u8005\u3002\u6211\u662F\u8BFA\u4E9A\uFF0C\u8FD9\u7247\u571F\u5730\u7684\u5B88\u62A4\u8005\u3002"
